# Google Gemini — geração de texto (autopost: scripts/facebookAutopost.js)
# e leitura de comprovantes Pix (POST /api/v1/financeiro/validar-comprovante)
GEMINI_API_KEY=
# Opcional: modelo de visão para comprovantes (padrão gemini-2.0-flash)
# GEMINI_VISION_MODEL=gemini-2.0-flash

# Pollinations.ai — imagens via Flux (chave gratuita: https://enter.pollinations.ai )
POLLINATIONS_API_KEY=

# Autopost → WhatsApp via Evolution API (scripts/facebookAutopost.js)
# Imagem: https://image.pollinations.ai/prompt/{prompt}?model=flux (gratuito)
# EVOLUTION_AUTOPOST_INSTANCE=axecloud_autopost
# EVOLUTION_AUTOPOST_INTEGRATION=baileys
# AUTOPOST_WHATSAPP_TO=5511920033501
# AUTOPOST_DRY_RUN=1

# Painel admin (axecloud-admin) — e-mails com acesso ao console global (vírgula)
ADMIN_CONSOLE_EMAILS=seu@email.com

# Supabase (front)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# ID do projeto (ref) — usado por scripts de migration/SQL
SUPABASE_PROJECT_REF=vlaojhfwhqmwudqsumpi
# Token pessoal para Management API (migrations via CLI/script)
# Gere em https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=

# Supabase (API / server)
SUPABASE_SERVICE_ROLE_KEY=
# Opcional: Secret API (sb_secret_…) para Metrics API no admin — senão usa SUPABASE_SERVICE_ROLE_KEY
# https://supabase.com/docs/guides/telemetry/metrics
# SUPABASE_METRICS_SECRET_KEY=

# URL pública do app (webhook EFI + links de boas-vindas)
APP_PUBLIC_URL=https://axecloud.com.br

# Google Search Console — tag HTML (content= do meta google-site-verification)
# Obtenha em https://search.google.com/search-console → Adicionar propriedade → Tag HTML
# GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools (opcional)
# BING_SITE_VERIFICATION=

# Google Business Profile — URL pública do perfil (JSON-LD Organization.sameAs)
# Ex.: https://www.google.com/maps?cid=... ou link share do perfil
# VITE_GOOGLE_BUSINESS_PROFILE_URL=

# Opcional: origens CORS extras (vírgula) além da lista padrão em api/lib/corsOrigins.ts
# ALLOWED_ORIGINS=https://meu-dominio.com.br

# EFI Bank / Efí Pay — Cobranças (cartão recorrente) + link legado
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
# true = sandbox (homologação)
EFI_SANDBOX=true
# Opcional: sobrescreve base da API (padrão: sandbox.gerencianet.com.br ou api.gerencianet.com.br)
# EFI_API_BASE_URL=https://sandbox.gerencianet.com.br
# Identificador de conta (painel Efí → API → Introdução) — obrigatório para tokenizar cartão no browser
# A API de Cobranças usa EFI_CLIENT_ID + EFI_CLIENT_SECRET; o payee code é só para o SDK do cartão.
EFI_PAYEE_CODE=
# Plano de assinatura existente (opcional; se vazio, o sistema cria "AxéCloud Premium")
# EFI_PREMIUM_PLAN_ID=
# Valor em centavos só se global_settings.plans não tiver preço (ex.: 500 = R$ 5,00 teste)
# EFI_PREMIUM_AMOUNT_CENTS=6990

# Santander API Pix (sandbox / produção) — certificado .crt + .key (mTLS)
# Gere localmente: openssl req -x509 -newkey rsa:2048 -sha256 -days 365 -nodes -keyout certs/santander-sandbox/santander-sandbox.key -out certs/santander-sandbox/santander-sandbox.crt -subj "/CN=AxeCloud Sandbox/O=AxeCloud/C=BR"
# Upload do .crt no portal developer.santander.com.br para obter Client ID / Secret
SANTANDER_CLIENT_ID=
SANTANDER_CLIENT_SECRET=
SANTANDER_SANDBOX=true
SANTANDER_PIX_KEY=
SANTANDER_WORKSPACE_ID=
# Local (padrão: ./certs/santander-sandbox/santander-sandbox.{crt,key})
# SANTANDER_CERT_CRT_PATH=./certs/santander-sandbox/santander-sandbox.crt
# SANTANDER_CERT_KEY_PATH=./certs/santander-sandbox/santander-sandbox.key
# Vercel/serverless: PEM em Base64
# SANTANDER_CERT_CRT_BASE64=
# SANTANDER_CERT_KEY_BASE64=
# Opcional: base da API (padrão trust-sandbox ou trust-open)
# SANTANDER_API_BASE_URL=https://trust-sandbox.api.santander.com.br
# Opcional: rota de cobrança Pix se o portal indicar path diferente
# SANTANDER_PIX_COBRANCA_PATH=

# EFI API Pix (QR Code instantâneo) — requer certificado .p12 da conta
EFI_PIX_KEY=
# Vercel/serverless: arquivo .p12 inteiro codificado em Base64 (recomendado na Vercel)
EFI_PIX_CERT_BASE64=
# Local: caminho para o certificado (ex.: ./certs/efi-producao.p12)
EFI_PIX_CERT_PATH=
# Senha do certificado (deixe vazio se não tiver senha)
# EFI_PIX_CERT_PASSPHRASE=
# Opcional: base da API Pix (padrão: pix-h.api.efipay.com.br ou pix.api.efipay.com.br)
# EFI_PIX_API_BASE_URL=

# Evolution API (WhatsApp boas-vindas pós-pagamento)
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
# URL pública da Evolution (webhook Meta Cloud API → {EVOLUTION_SERVER_URL}/webhook/meta)
EVOLUTION_SERVER_URL=https://axecloud.com.br
# Meta Cloud API (envio direto — preferido sobre Evolution quando preenchido)
# WA_META_TOKEN=
# WA_PHONE_NUMBER_ID=1145309432000023
# WA_BUSINESS_ACCOUNT_ID=
# WA_BUSINESS_VERSION=v21.0
# Verify Token do painel Meta — deve ser idêntico ao WA_BUSINESS_TOKEN_WEBHOOK no container evolution
# e ao "Verify token" do webhook em developers.facebook.com (Callback URL: https://axecloud.com.br/api/whatsapp/webhook)
# Gere com: openssl rand -hex 32
WA_BUSINESS_TOKEN_WEBHOOK=
# Opcional: App Secret do app Meta para validar X-Hub-Signature-256 nos callbacks de status
# WA_META_APP_SECRET=
# Template Meta — fallback genérico
WA_META_TEMPLATE_DEFAULT=aviso_geral_axecloud
# Cadastro / reenvio de credenciais: conta_ativa_axecloud
WA_META_TEMPLATE_DADOS_ACESSO=conta_ativa_axecloud
# 2ª mensagem (registro + senha) — template dedicado; se ausente, usa aviso_geral_axecloud
WA_META_TEMPLATE_CREDENCIAIS_ACESSO=credenciais_acesso_axecloud
# Cobrança manual (Financeiro): cobranca_mensalidade_axecloud — {{1}} filho {{2}} mês/ano {{3}} valor {{4}} terreiro
WA_META_TEMPLATE_COBRANCA_MENSALIDADE=cobranca_mensalidade_axecloud
# Pagamento confirmado: mensalidade_confirmada_axecloud — {{1}} filho {{2}} competência {{3}} valor {{4}} terreiro
WA_META_TEMPLATE_MENSALIDADE_CONFIRMADA=mensalidade_confirmada_axecloud
# WA_CREDENTIALS_FOLLOWUP_DELAY_MS=4000
# WA_META_SYSTEM_NAME=AxéCloud
# WA_APP_LOGIN_URL=https://axecloud.com.br
# Convites RSVP: convite_evento_axecloud — header imagem; corpo {{1}} terreiro {{2}} título {{3}} data {{4}} hora {{5}} local
WA_META_TEMPLATE_CONVITE_EVENTO=convite_evento_axecloud
# Banner padrão se o evento não tiver imagem (header obrigatório)
# WA_META_EVENT_DEFAULT_BANNER_URL=https://axecloud.com.br/og-image.png
# Avisos de gira/evento (membros da corrente): aviso_gira_axecloud — header banner + {{1}} título {{2}} data {{3}} hora
WA_META_TEMPLATE_AVISO_GIRA=aviso_gira_axecloud
# Mural de avisos: mural_aviso_axecloud — corpo {{1}} filho {{2}} terreiro {{3}} título do aviso
WA_META_TEMPLATE_MURAL_AVISO=mural_aviso_axecloud
# Financeiro (cron 09h + lembrete manual): financeiro_axecloud — {{1}} filho {{2}} valor {{3}} vencimento {{4}} terreiro
WA_META_TEMPLATE_FINANCEIRO=financeiro_axecloud
# Estoque crítico (zelador): estoque_critico_axecloud — {{1}} item {{2}} quantidade {{3}} terreiro
WA_META_TEMPLATE_ESTOQUE_CRITICO=estoque_critico_axecloud
# Pedido de reza: novo → zelador; aceito → fiel
WA_META_TEMPLATE_PEDIDO_REZA_NOVO_ZELADOR=pedido_reza_novo_zelador_axecloud
WA_META_TEMPLATE_PEDIDO_REZA_ACEITO_FIEL=pedido_reza_aceito_fiel_axecloud
# Senha visitante (portaria): senha_evento_visitante_axecloud — 6 vars + botão URL /presenca/
WA_META_TEMPLATE_SENHA_EVENTO_VISITANTE=senha_evento_visitante_axecloud
# Transmissão mural / broadcast / teste — aviso_portal_axecloud (2 vars + texto livre na sequência)
WA_META_TEMPLATE_TRANSMISSAO_AVISO=aviso_portal_axecloud
WA_META_TEMPLATE_BROADCAST=aviso_portal_axecloud
# Legado (rejeitados na Meta): comunicado_terreiro_axecloud, mensagem_livre_terreiro_axecloud
# WA_META_TEMPLATE_BROADCAST=comunicado_terreiro_axecloud
# WA_TRANSMISSAO_FOLLOWUP_DELAY_MS=4000
WA_META_TEMPLATE_LANGUAGE=pt_BR
# Na VPS (deploy/docker-compose.yml): Redis interno — CACHE_REDIS_URI=redis://redis:6379/6

# --- Anti-spam WhatsApp (Evolution/Baileys) ---
# Janela de envio (horário de Brasília) — aplica só a transmissões em massa (campanhas).
# Envios pontuais (dados de acesso, financeiro, OTP) funcionam a qualquer hora.
# WA_ENFORCE_SEND_WINDOW=1
# WA_SEND_WINDOW_START_HOUR=8
# WA_SEND_WINDOW_END_HOUR=20
# WA_SEND_WINDOW_WEEKEND_START_HOUR=9
# WA_SEND_WINDOW_WEEKEND_END_HOUR=19
# Delays entre mensagens (ms) — quanto maior, menor risco de restrição Meta
# WA_SEND_MIN_DELAY_MS=6000
# WA_SEND_MAX_DELAY_MS=18000
# WA_SEND_PHONE_COOLDOWN_MS=120000
# WA_CAMPAIGN_MIN_DELAY_MS=20000
# WA_CAMPAIGN_MAX_DELAY_MS=60000
# WA_NOTIFICATION_MIN_DELAY_MS=8000
# WA_NOTIFICATION_MAX_DELAY_MS=18000
# Cotas globais (contadas no banco — funcionam em serverless)
# WA_SEND_HOURLY_MAX=40
# WA_SEND_DAILY_MAX=250
# Cotas por terreiro
# WA_TENANT_DAILY_MAX=60
# WA_BROADCAST_MAX_RECIPIENTS=25
# WA_FANOUT_MAX_RECIPIENTS=30
# WA_BROADCAST_COOLDOWN_MS=600000
# WA_FANOUT_COOLDOWN_MS=300000
# Mesmo conteúdo repetido (fingerprint) por terreiro
# WA_CAMPAIGN_FINGERPRINT_HOURLY_MAX=25
# WA_CAMPAIGN_FINGERPRINT_DAILY_MAX=80

# Webhooks / ativação manual / cron
WHATSAPP_WEBHOOK_SECRET=
EFI_WEBHOOK_SECRET=
CRON_SECRET=
ONBOARDING_ACTIVATE_SECRET=
# VAPID Web Push — par público/privado (mesmo par no servidor e no PWA)
# Servidor aceita VAPID_PUBLIC_KEY ou, em fallback, VITE_VAPID_PUBLIC_KEY (mesmo valor).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Front build — só chave pública (deve ser idêntica a VAPID_PUBLIC_KEY)
VITE_VAPID_PUBLIC_KEY=
# PDF proxy — hosts extras permitidos (vírgula), além de *.supabase.co
PDF_PROXY_ALLOWED_HOSTS=
# Previews Vercel no CORS (1 = habilita *.vercel.app)
VERCEL_PREVIEW_CORS=0
