# Painel admin (axecloud-admin) — e-mails com acesso ao console global (vírgula)
ADMIN_CONSOLE_EMAILS=seu@email.com

# Supabase (front)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase (API / server)
SUPABASE_SERVICE_ROLE_KEY=
# Opcional: Secret API (sb_secret_…) para Metrics API no admin — senão usa SUPABASE_SERVICE_ROLE_KEY
# https://supabase.com/docs/guides/telemetry/metrics
# SUPABASE_METRICS_SECRET_KEY=

# URL pública do app (webhook EFI + links de boas-vindas)
APP_PUBLIC_URL=https://axecloud.com.br

# Opcional: origens CORS extras (vírgula) além da lista padrão em api/lib/corsOrigins.ts
# ALLOWED_ORIGINS=https://meu-dominio.com.br

# EFI Bank / Efí Pay — Cobranças (cartão recorrente) + link legado
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
# true = sandbox (homologação)
EFI_SANDBOX=true
# Opcional: sobrescreve base da API (padrão: sandbox.gerencianet.com.br ou api.gerencianet.com.br)
# EFI_API_BASE_URL=https://sandbox.gerencianet.com.br
# Identificador de conta (painel Efí → API → Introdução) — obrigatório para tokenizar cartão no browser
# A API de Cobranças usa EFI_CLIENT_ID + EFI_CLIENT_SECRET; o payee code é só para o SDK do cartão.
EFI_PAYEE_CODE=
# Plano de assinatura existente (opcional; se vazio, o sistema cria "AxéCloud Premium")
# EFI_PREMIUM_PLAN_ID=
# Valor em centavos só se global_settings.plans não tiver preço (ex.: 500 = R$ 5,00 teste)
# EFI_PREMIUM_AMOUNT_CENTS=6990

# EFI API Pix (QR Code instantâneo) — requer certificado .p12 da conta
EFI_PIX_KEY=
# Vercel/serverless: arquivo .p12 inteiro codificado em Base64 (recomendado na Vercel)
EFI_PIX_CERT_BASE64=
# Local: caminho para o certificado (ex.: ./certs/efi-producao.p12)
EFI_PIX_CERT_PATH=
# Senha do certificado (deixe vazio se não tiver senha)
# EFI_PIX_CERT_PASSPHRASE=
# Opcional: base da API Pix (padrão: pix-h.api.efipay.com.br ou pix.api.efipay.com.br)
# EFI_PIX_API_BASE_URL=

# Evolution API (WhatsApp boas-vindas pós-pagamento)
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
# Na VPS (deploy/docker-compose.yml): Redis interno — CACHE_REDIS_URI=redis://redis:6379/6

# Webhooks / ativação manual
WHATSAPP_WEBHOOK_SECRET=
ONBOARDING_ACTIVATE_SECRET=
# PDF proxy — hosts extras permitidos (vírgula), além de *.supabase.co
PDF_PROXY_ALLOWED_HOSTS=
# Previews Vercel no CORS (1 = habilita *.vercel.app)
VERCEL_PREVIEW_CORS=0
