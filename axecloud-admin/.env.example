# ===== axecloud-admin · variáveis públicas (Vite) =====
# Tudo o que começa com VITE_ é embutido no bundle do browser.
# NUNCA coloque service_role ou segredos do servidor aqui.

# Mesmo projecto Supabase que o app principal (use a anon key).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...

# (Opcional, apenas DEV) Proxy do Vite para o backend Express local.
# Em produção (Vercel) as chamadas /api/* são reescritas para o app principal
# via axecloud-admin/vercel.json — não use esta variável em produção.
VITE_PROXY_API=http://localhost:3000
