{
	email {$ACME_EMAIL}
	crowdsec {
		api_url http://crowdsec:8080
		api_key {$CROWDSEC_CADDY_API_KEY}
		ticker_interval 30s
		appsec_url http://crowdsec:7422
	}
	servers {
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
		trusted_proxies_strict
		client_ip_headers CF-Connecting-IP X-Forwarded-For
	}
}

(app_upstream) {
	reverse_proxy app:3000 {
		header_up X-AxeCloud-Client-IP {client_ip}
		health_uri /api/health-check
		health_interval 5s
		health_timeout 3s
		fail_duration 15s
		# Durante restart do container app, retenta em vez de 503 imediato
		lb_try_duration 30s
		lb_try_interval 250ms
	}
}

axecloud.com.br, www.axecloud.com.br {
	@www host www.axecloud.com.br
	redir @www https://axecloud.com.br{uri} permanent

		log {
		output file /var/log/caddy/access.log {
			roll_size 10MiB
			roll_keep 5
			mode 0640
		}
		format json
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(self), geolocation=(self)"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://sdk.pagseguro.uol.com.br https://*.efi.com.br https://*.gerencianet.com.br https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.efi.com.br https://*.gerencianet.com.br https://cloudflareinsights.com https://*.r2.cloudflarestorage.com https://*.r2.dev https://*.backblazeb2.com https://s3.us-east-005.backblazeb2.com https://*.s3.us-east-005.backblazeb2.com; frame-src 'self' https://*.efi.com.br https://*.gerencianet.com.br; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self' https://*.efi.com.br https://*.gerencianet.com.br; upgrade-insecure-requests"
		-Server
	}

	route {
		# Typo comum no GSC: sitemap.xm → sitemap.xml (antes de crowdsec/appsec)
		handle /sitemap.xm {
			redir * /sitemap.xml permanent
		}

		handle /sitemap.xml {
			import app_upstream
		}

		@diretorio_crawlers {
			path /terreiro/*
			path /terreiros/*/*
			header_regexp User-Agent (?i)(googlebot|bingbot|yandex|baiduspider|facebookexternalhit|twitterbot|linkedinbot|slackbot|discordbot|whatsapp|telegrambot|applebot|petalbot|semrushbot|ahrefsbot|mj12bot|dotbot|crawler|spider)
		}
		handle @diretorio_crawlers {
			@terreiro_page path /terreiro/*
			handle @terreiro_page {
				rewrite * /api/v1/public/diretorio/render{path}
				import app_upstream
			}
			@city_page path /terreiros/*/*
			handle @city_page {
				rewrite * /api/v1/public/diretorio/render/{path.1}/{path.2}
				import app_upstream
			}
		}

		crowdsec
		appsec

		# Login legado (com ou sem barra) vai direto ao destino canonico.
		# A regra precisa vir antes da normalizacao geral para evitar dois redirects.
		@legacyLogin path /login /login/
		handle @legacyLogin {
			redir * /entrar permanent
		}

		@trailingSlash path_regexp trailing ^(.+)/$
		redir @trailingSlash {re.trailing.1} permanent

		@scanners {
			path /.env
			path /.env.*
			path /.git*
			path /wp-admin*
			path /wp-login.php
			path /phpmyadmin*
			path /pma*
			path /xmlrpc.php
			path /vendor/phpunit*
			path /actuator*
			path /containers/json
		}
		handle @scanners {
			respond 404
		}

		@api_sensitive {
			path /api/auth*
			path /api/whatsapp*
			path /api/v1/auth/*
			path /api/v1/checkout/*
			path /api/webhooks/*
			path /api/v1/founder-program/*
			path /api/v1/public/*
		}
		handle @api_sensitive {
			rate_limit {
				zone api_sensitive {
					key {client_ip}
					events 60
					window 1m
				}
			}
			import app_upstream
		}

		@api path /api/*
		handle @api {
			rate_limit {
				zone api_general {
					key {client_ip}
					events 300
					window 1m
				}
			}
			import app_upstream
		}

		# Meta Cloud API (número oficial) — callback na Meta é /webhook/meta.
		# Vai para o app (Caixa WA); demais /webhook/* seguem na Evolution.
		@meta_cloud_webhook path /webhook/meta /webhook/meta/
		handle @meta_cloud_webhook {
			rate_limit {
				zone meta_cloud_webhook {
					key {client_ip}
					events 120
					window 1m
				}
			}
			import app_upstream
		}

		@evolution_webhook path /webhook/*
		handle @evolution_webhook {
			rate_limit {
				zone evolution_webhook {
					key {client_ip}
					events 60
					window 1m
				}
			}
			reverse_proxy evolution:8080
		}

		@massets path /m-assets/*
		handle @massets {
			reverse_proxy marketing:80
		}

		@public_static {
			path /robots.txt
			path /og-image.png
			path /logo-topo-matriz.png
			path /diretorio-cidades.json
			path /diretorio-snapshot.json
			path /screenshots/*
		}
		# Ícones PWA/favicon: sempre do container app (dist atualizado no deploy)
		@pwa_icons {
			path /favicon.ico
			path /manifest.webmanifest
			path /sw.js
			path /build-info.json
			path /axecloud_*.png
			path /pwa-*.png
			path /logo-axecloud.png
		}
		handle @pwa_icons {
			import app_upstream
		}
		handle @public_static {
			reverse_proxy marketing:80
		}

		@ready_posts path /ready-posts/*
		handle @ready_posts {
			uri strip_prefix /ready-posts
			root * /srv/ready_posts
			file_server
		}

		@legacy_founder {
			path /programa-fundador
			path /programa-fundador/*
		}
		handle @legacy_founder {
			redir * /register permanent
		}

		@marketing {
			path /
			path /register
			path /register/*
			path /termos
			path /termos/*
			path /privacidade
			path /privacidade/*
			path /por-que-axecloud
			path /por-que-axecloud/*
			path /espaco-do-fiel
			path /espaco-do-fiel/*
			path /terreiros
			path /terreiros/*
			path /terreiro
			path /terreiro/*
			path /eventos
			path /eventos/*
			path /evento
			path /evento/*
			path /conteudo
			path /conteudo/*
		}
		handle @marketing {
			reverse_proxy marketing:80
		}

		handle {
			import app_upstream
		}
	}
}

admin.axecloud.com.br {
	log {
		output file /var/log/caddy/admin-access.log {
			roll_size 10MiB
			roll_keep 5
			mode 0640
		}
		format json
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	route {
		crowdsec
		appsec

		@api path /api/*
		handle @api {
			rate_limit {
				zone admin_api_general {
					key {client_ip}
					events 120
					window 1m
				}
			}
			import app_upstream
		}

		handle {
			reverse_proxy admin:80
		}
	}
}
