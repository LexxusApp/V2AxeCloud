{
	email {$ACME_EMAIL}
}

axecloud.com.br, www.axecloud.com.br {
	@www host www.axecloud.com.br
	redir @www https://axecloud.com.br{uri} permanent

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	@scanners {
		path /.env*
		path /.git*
		path /wp-admin*
		path /wp-login.php
		path /phpmyadmin*
		path /pma*
		path /xmlrpc.php
		path /vendor/phpunit*
		path /actuator*
		path /containers/json
	}
	respond @scanners 404

	# API sempre no app Node
	@api path /api/*
	handle @api {
		reverse_proxy app:3000
	}

	# Assets do marketing (prefixo dedicado — não colide com /assets/ do app)
	@massets path /m-assets/*
	handle @massets {
		reverse_proxy marketing:80
	}

	# Estáticos compartilhados (screenshots, ícones, SEO)
	@public_static {
		path /favicon.ico
		path /robots.txt
		path /sitemap.xml
		path /og-image.png
		path /screenshots/*
		path /axecloud_*.png
	}
	handle @public_static {
		reverse_proxy marketing:80
	}

	# Páginas públicas de marketing (site leve)
	@marketing {
		path /
		path /termos
		path /termos/*
		path /privacidade
		path /privacidade/*
		path /programa-fundador
		path /programa-fundador/*
		path /conteudo
		path /conteudo/*
	}
	handle @marketing {
		reverse_proxy marketing:80
	}

	# App SPA: login, cadastro, painel, convites, portal consulente, PWA
	handle {
		reverse_proxy app:3000
	}
}
