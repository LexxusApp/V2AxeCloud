{
  "env": {
    "NODE_OPTIONS": "--disable-warning=DEP0169"
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.axecloud.com.br" }],
      "destination": "https://axecloud.com.br/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth/filho-login",
      "destination": "/api/auth?action=filho-login"
    },
    {
      "source": "/api/auth/audit-log",
      "destination": "/api/auth?action=audit-log"
    },
    {
      "source": "/api/tenant-info",
      "destination": "/api/public?route=tenant-info"
    },
    {
      "source": "/api/plans",
      "destination": "/api/public?route=plans"
    },
    {
      "source": "/api/v1/checkout/efi/:path*",
      "destination": "/api/checkout?path=:path*"
    },
    {
      "source": "/api/admin/tenants",
      "destination": "/api/admin?action=tenants"
    },
    {
      "source": "/api/admin/manage-tenant",
      "destination": "/api/admin?action=manage-tenant"
    },
    {
      "source": "/api/admin/create-tenant",
      "destination": "/api/admin?action=create-tenant"
    },
    {
      "source": "/api/admin/update-plans",
      "destination": "/api/admin?action=update-plans"
    },
    {
      "source": "/api/admin-console/session",
      "destination": "/api/admin-console?target=session"
    },
    {
      "source": "/api/admin-console/overview",
      "destination": "/api/admin-console?target=overview"
    },
    {
      "source": "/api/admin-console/activity",
      "destination": "/api/admin-console?target=activity"
    },
    {
      "source": "/api/admin-console/audit-logs",
      "destination": "/api/admin-console?target=audit-logs"
    },
    {
      "source": "/api/admin-console/r2-usage",
      "destination": "/api/admin-console?target=r2-usage"
    },
    {
      "source": "/api/admin-console/:path*",
      "destination": "/api/admin-console?target=:path*"
    },
    {
      "source": "/api/v1/cron/ping-evolution",
      "destination": "/api/cron?job=ping-evolution"
    },
    {
      "source": "/api/cron/audit-tick",
      "destination": "/api/cron?job=audit-tick"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' data: blob: https://*.supabase.co; base-uri 'self'; frame-ancestors 'self'; form-action 'self'; object-src 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://axecloud.com.br https://www.axecloud.com.br https://tokenizer.sejaefi.com.br https://*.gerencianet.com.br https://*.efipay.com.br https://device.clearsale.com.br https://cdn.jsdelivr.net; script-src-elem 'self' 'unsafe-inline' https://axecloud.com.br https://www.axecloud.com.br https://tokenizer.sejaefi.com.br https://*.gerencianet.com.br https://*.efipay.com.br https://device.clearsale.com.br https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src-elem 'self' 'unsafe-inline' https://axecloud.com.br https://www.axecloud.com.br https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https://axecloud.com.br https://www.axecloud.com.br https://*.supabase.co https://*.r2.cloudflarestorage.com https://*.r2.dev https://images.unsplash.com https://device.clearsale.com.br https://web.fpcs-monitor.com.br; connect-src 'self' https://axecloud.com.br https://www.axecloud.com.br https://tokenizer.sejaefi.com.br https://*.gerencianet.com.br https://*.efipay.com.br https://device.clearsale.com.br https://web.fpcs-monitor.com.br https://*.supabase.co wss://*.supabase.co https://*.r2.cloudflarestorage.com https://*.r2.dev https://cdn.jsdelivr.net https://vitals.vercel-insights.com https://va.vercel-scripts.com; frame-src 'self' https://tokenizer.sejaefi.com.br; worker-src 'self' blob:; manifest-src 'self' https://axecloud.com.br https://www.axecloud.com.br https://axecloud-app.vercel.app; upgrade-insecure-requests"
        },
        {
          "key": "X-Permitted-Cross-Domain-Policies",
          "value": "none"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "off"
        },
        {
          "key": "X-Powered-By",
          "value": ""
        },
        {
          "key": "Server",
          "value": ""
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/((?!api|assets|.*\\..*).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/sw-push.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/og-image.png",
      "headers": [
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, immutable"
        },
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        },
        {
          "key": "Content-Type",
          "value": "image/x-icon"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, immutable"
        }
      ]
    },
    {
      "source": "/axecloud_48.png",
      "headers": [
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        }
      ]
    },
    {
      "source": "/axecloud_192.png",
      "headers": [
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        }
      ]
    },
    {
      "source": "/axecloud_512.png",
      "headers": [
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        }
      ]
    },
    {
      "source": "/login-bg.png",
      "headers": [
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, immutable"
        }
      ]
    },
    {
      "source": "/login-bg-premium.png",
      "headers": [
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, immutable"
        }
      ]
    },
    {
      "source": "/login-bg-desktop.png",
      "headers": [
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, immutable"
        }
      ]
    }
  ]
}
